											"_id": "AAAAAAGdKaKA7Vf9/Jk=",
											"_parent": {
												"$ref": "AAAAAAGdKZD6kFW34wE="
											},
											"font": "Arial;13;0",
											"left": 816,
											"top": 328,
											"width": 312,
											"height": 120,
											"text": "Etape 8 : Scénario d'Erreur\nL'modification de la prestation n'est pas validé par l'utilisateur.\n8.1 Envoyer un message à l'utilisateur\n8.2 Arrêter le scénario\nDans le scénario nominal, l'utilisateur a validé la modification de la prestation."
										},
										{
											"_type": "UMLNoteView",
											"_id": "AAAAAAGdKaRoa1gDdqc=",
											"_parent": {
												"$ref": "AAAAAAGdKZD6kFW34wE="
											},
											"font": "Arial;13;0",
											"left": 816,
											"top": 488,
											"width": 312,
											"height": 112,
											"text": "Etape 12 : Scénario d'Erreur\nIl y a eu un problème avec les données.\n12.1 Afficher un message d'erreur à l'utilisateur\n12.2 Arrêter le scénario\nDans le scénario nominal, la modification de la prestation a été correctement effectuée."
										}
									]
								}
							],
